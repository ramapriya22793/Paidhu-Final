{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.paidhu.com"
        }
      ],
      "destination": "https://paidhu.com/$1",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.ico|manifest\\.json|robots\\.txt|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}

